{
  "name": "@ewanc26/atproto",
  "version": "0.1.0",
  "description": "AT Protocol service layer extracted from ewancroft.uk",
  "type": "module",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "types": "./dist/index.d.ts",
