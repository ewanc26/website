{
	"name": "website",
	"private": true,
	"version": "11.7.0",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --write .",
		"lint": "prettier --check .",
		"version": "node -e \"const fs=require('fs'),v=process.env.npm_package_version,c=fs.readFileSync('README.md','utf8');fs.writeFileSync('README.md',c.replace(/\\*\\*Version\\*\\*: .+/,'**Version**: '+v));\" && git add README.md"
	},
	"devDependencies": {
		"@sveltejs/adapter-vercel": "^6.3.3",
		"@sveltejs/kit": "^2.55.0",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"@tailwindcss/typography": "^0.5.19",
		"@tailwindcss/vite": "^4.2.2",
		"@types/node": "^25.5.0",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"svelte": "^5.54.1",
		"svelte-check": "^4.4.5",
		"tailwindcss": "^4.2.2",
		"typescript": "^5.9.3",
		"vercel": "^50.42.0",
		"vite": "^7.3.1"
	},
	"pnpm": {
		"onlyBuiltDependencies": [
			"esbuild"
		]
	},
	"dependencies": {
		"@atproto/api": "^0.18.21",
		"@ewanc26/atproto": "^0.2.8",
		"@ewanc26/noise-avatar": "^0.2.3",
		"@ewanc26/og": "^0.1.2",
		"@ewanc26/supporters": "^0.3.0",
		"@ewanc26/tid": "^1.1.3",
		"@ewanc26/ui": "^0.3.8",
		"@ewanc26/utils": "^0.1.5",
		"@lucide/svelte": "^0.554.0",
		"hls.js": "^1.6.15"
	}
}
